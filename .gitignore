# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock files (optional - uncomment if you want to commit lock files)
# .terraform.lock.hcl

# Ignore IDE files
.idea/
*.swp
*.swo
*~
.DS_Store

# Ignore OS files
Thumbs.db

# Ignore module cache
.terraform.lock.hcl
