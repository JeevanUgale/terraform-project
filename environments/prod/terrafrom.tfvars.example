# Production Environment Terraform Values
# This file contains environment-specific variable values for production

# AWS
aws_region = "us-east-1"

# Project
project_name = "3-tier-app"
owner        = "DevOps Team"
cost_center  = "Engineering"
environment  = "prod"

# VPC - Higher availability with 3 AZs
vpc_cidr                = "10.1.0.0/16"
availability_zones      = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs     = ["10.1.1.0/24", "10.1.2.0/24", "10.1.3.0/24"]
private_subnet_cidrs    = ["10.1.10.0/24", "10.1.11.0/24", "10.1.12.0/24"]

# EC2 - Larger instance for production
instance_type           = "t3.small"
key_name                = "prod-key" # Change to your EC2 Key Pair name
allowed_ssh_cidr        = "10.1.0.0/16" # Restrict SSH to VPC CIDR

# RDS Database - PostgreSQL for production
db_engine               = "postgres"
db_engine_version       = "15.3"
db_instance_class       = "db.t3.small"
allocated_storage       = 100
db_username             = "postgres"
db_password             = "ProdPassword@Secure123!" # IMPORTANT: Use a strong password - change this
db_name                 = "proddb"
backup_retention_period = 30  # 30 days retention in production
multi_az                = true # Multi-AZ for high availability

# S3 - With versioning and lifecycle
s3_bucket_name          = "3-tier-app-bucket-prod-12345" # Must be globally unique - change the numbers
versioning_enabled      = true
encryption_enabled      = true
enable_lifecycle_rules  = true
